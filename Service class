package com.barclaycardus.dynamicurl.service.impl;

import com.barclaycardus.digital.masking.MaskingUtil;
import com.barclaycardus.dynamicurl.constant.enums.ServiceErrorCodes;
import com.barclaycardus.dynamicurl.entity.UrlInformation;
import com.barclaycardus.dynamicurl.exception.GenerateURLValidationException;
import com.barclaycardus.dynamicurl.exception.InvalidRequestException;
import com.barclaycardus.dynamicurl.exception.ResourceNotFoundException;
import com.barclaycardus.dynamicurl.exception.UrlStateUpdateException;
import com.barclaycardus.dynamicurl.model.OperationType;
import com.barclaycardus.dynamicurl.model.*;
import com.barclaycardus.dynamicurl.processor.ResponseProcessor;
import com.barclaycardus.dynamicurl.repository.UrlDynamoDbRepository;
import com.barclaycardus.dynamicurl.service.DynamicUrlService;
import com.barclaycardus.dynamicurl.service.URLValidatorService;
import com.barclaycardus.dynamicurl.service.factory.ServiceFactory;
import org.apache.commons.collections.CollectionUtils;
import org.owasp.encoder.Encode;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import software.amazon.awssdk.services.dynamodb.DynamoDbClient;
import software.amazon.awssdk.services.dynamodb.model.*;

import java.time.Instant;
import java.util.Arrays;
import java.util.Collections;
import java.util.List;
import java.util.Map;

@Service
public class DynamicUrlServiceImpl implements DynamicUrlService {

  @Autowired private DynamoDbClient dynamoDbClient;
  @Autowired private UrlDynamoDbRepository repository;
  @Autowired private DynamicUrlServiceHelper helper;
  @Autowired private ServiceFactory factory;
  @Autowired private ResponseProcessor responseProcessor;

  @Value("${aws.dynamodb.table-name}")
  private String tableName;

  private static final Logger LOG = LoggerFactory.getLogger(DynamicUrlServiceImpl.class);

  @Override
  public GenerateUrlResponseData generateUrl(
    String correlationID,
    String traceId,
    String spanId,
    GenerateUrlRequestData requestData,
    String channelId,
    String userId) {

    GenerateUrlRequest request = requestData.getData();

    validateRequestIfRequired(request);

    String encodedUser = encode(userId);
    String maskedContact = mask(request.getContact());

    LOG.info("Generating URL for contact: {}", maskedContact);

    List<UrlInformation> existingUrls = fetchExistingUrls(request);

    UrlInformation prevActiveUrl = getActiveUrlIfValid(existingUrls, maskedContact);

    UrlInformation newUrl = helper.generateNewUrl(request, userId, channelId, prevActiveUrl);

    persistUrl(prevActiveUrl, newUrl, encodedUser);

    LOG.info("URL generated successfully for contact: {}", maskedContact);

    return responseProcessor.processGenerateURLResponse(newUrl);
  }

  @Override
  public ValidateUrlResponseData validateUrl(String correlationID, String traceId, String spanId, String urlId) {
    LOG.info("Validating URL Id: {}", encode(urlId));

    UrlInformation url = getUrlOrThrow(urlId);

    ValidationResult result = validateWithFactory(url, OperationType.VALIDATE_URL.name());

    LOG.info("URL Id: {} isValid: {}", encode(urlId), result.isValid());

    return responseProcessor.processValidateUrlResponse(result);
  }

  @Override
  public URLInformationData getURLDetails(String correlationID, String traceId, String spanId, String urlId) {
    LOG.info("Fetch URL details of urlId: {}", encode(urlId));

    UrlInformation url = getUrlOrThrow(urlId);

    return responseProcessor.processUrlDetailsResponse(url);
  }

  @Override
  public URLInformationData getURLDetail(String correlationID, String traceId, String spanId, String urlId) {
    LOG.info("Fetch URL details of urlId: {}", encode(urlId));

    UrlInformation url = getUrlOrThrow(urlId);

    URLInformationData data = responseProcessor.processUrlDetailsResponse(url);
    data.getData().setUrlExpiry(String.valueOf(url.getExpireOn()));

    return data;
  }

  @Override
  public URLInformationData updateURLState(
    String correlationID,
    String traceId,
    String spanId,
    String urlId,
    UrlStateUpdateReqData reqData,
    String userId) {

    String encodedUser = encode(userId);
    LOG.info("Updating URL state for urlId: {}", encode(urlId));

    UrlInformation url = getUrlOrThrow(urlId);

    validateUrlStateUpdate(url);

    UrlStateUpdateRequest request = reqData.getData();

    UrlStateUpdateService service = factory.getService(request.getStateAttribute().name());

    UrlInformation updated = service.updateUrlState(request, url, userId);

    return responseProcessor.processUrlDetailsResponse(updated);
  }

  private void validateRequestIfRequired(GenerateUrlRequest request) {
    if (shouldValidate(request)) {
      validateRequestParams(request);
    }
  }

  private boolean shouldValidate(GenerateUrlRequest request) {
    return request.getJourneyCode() != null &&
      !(request.getJourneyCode().getValue().equalsIgnoreCase("texttolookup")
        || request.getJourneyCode().getValue().equalsIgnoreCase("acq"));
  }

  private void validateRequestParams(GenerateUrlRequest request) {
    validateField(request.getContact(), "Contact");
    validateField(request.getPartnerCode(), "PartnerCode");

    if (request.getContactType() == null) {
      throwBadRequest("ContactType", request.getContact());
    }

    validateExpiry(request.getUrlExpiry(), request.getContact());
    validateField(request.getPartnerOrgUUID(), "PartnerOrgUUID");
  }

  private void validateField(String value, String field) {
    if (isNullOrEmpty(value)) {
      throwBadRequest(field, value);
    }
  }

  private void validateExpiry(String expiry, String contact) {
    if (expiry == null || expiry.isEmpty()) return;

    try {
      Instant expiryTime = Instant.parse(expiry);
      if (expiryTime.isBefore(Instant.now())) {
        throwBadRequest("UrlExpiry", contact);
      }
    } catch (Exception e) {
      throw new InvalidRequestException("Invalid expiry format", ServiceErrorCodes.BAD_REQUEST);
    }
  }

  private List<UrlInformation> fetchExistingUrls(GenerateUrlRequest request) {
    return repository.findByContactAndJourneyCodeAndCreatedOn(
      request.getContact(),
      request.getJourneyCode().getValue(),
      0,
      Arrays.asList(
        UrlStatusEnum.ADMIN_LOCKED.getValue(),
        UrlStatusEnum.ACTIVE.getValue()));
  }

  private UrlInformation getActiveUrlIfValid(List<UrlInformation> urls, String maskedContact) {
    if (CollectionUtils.isEmpty(urls)) return null;

    URLValidatorService validator = factory.getService(OperationType.GENERATE_URL.name());
    ValidationResult result = validator.validate(urls);

    if (!result.isValid()) {
      throw new GenerateURLValidationException(
        "Url generation failed for contact: " + maskedContact,
        ServiceErrorCodes.valueOf(result.getErrorCode()));
    }

    return urls.stream()
      .filter(u -> UrlStatusEnum.ACTIVE.getValue().equals(u.getStatus()))
      .findFirst()
      .orElse(null);
  }

  private void persistUrl(UrlInformation prev, UrlInformation current, String userId) {
    if (prev == null) {
      repository.save(current);
    } else {
      executeTransaction(prev, current, userId);
    }
  }

  private void executeTransaction(UrlInformation prev, UrlInformation current, String userId) {
    long now = Instant.now().getEpochSecond();

    TransactWriteItemsRequest tx = TransactWriteItemsRequest.builder()
      .transactItems(
        buildUpdateItem(prev, userId, now),
        buildPutItem(current))
      .build();

    dynamoDbClient.transactWriteItems(tx);
  }

  private TransactWriteItem buildUpdateItem(UrlInformation prev, String userId, long now) {
    return TransactWriteItem.builder()
      .update(Update.builder()
        .tableName(tableName)
        .key(Map.of("urlId", AttributeValue.builder().s(prev.getUrlId()).build()))
        .updateExpression("SET #st = :inactive, updatedOn = :now, updatedBy = :user")
        .conditionExpression("#st = :active")
        .expressionAttributeNames(Map.of("#st", "status"))
        .expressionAttributeValues(Map.of(
          ":inactive", attr(UrlStatusEnum.INACTIVE.getValue()),
          ":active", attr(UrlStatusEnum.ACTIVE.getValue()),
          ":now", num(now),
          ":user", attr(userId)))
        .build())
      .build();
  }

  private TransactWriteItem buildPutItem(UrlInformation url) {
    return TransactWriteItem.builder()
      .put(Put.builder()
        .tableName(tableName)
        .item(buildItemMap(url))
        .conditionExpression("attribute_not_exists(urlId)")
        .build())
      .build();
  }

  private Map<String, AttributeValue> buildItemMap(UrlInformation url) {

  Map<String, AttributeValue> map = new HashMap<>();

  addString(map, "urlId", url.getUrlId());
  addString(map, "contact", url.getContact());
  addString(map, "workflowCode", url.getWorkflowCode());
  addString(map, "status", url.getStatus());
  addString(map, "createdBy", url.getCreatedBy());

  addNumber(map, "createdOn", url.getCreatedOn());
  addNumber(map, "expiryAt", url.getExpireOn());

  return map;
}

  private UrlInformation getUrlOrThrow(String urlId) {
    UrlInformation url = repository.findByUrlId(urlId);
    if (url == null) {
      throw new ResourceNotFoundException("URL not found for urlId:" + urlId);
    }
    return url;
  }

  private ValidationResult validateWithFactory(UrlInformation url, String operation) {
    URLValidatorService validator = factory.getService(operation);
    return validator.validate(Collections.singletonList(url));
  }

  private void validateUrlStateUpdate(UrlInformation url) {
    ValidationResult result = validateWithFactory(url, OperationType.URL_STATE_UPDATE.name());
    if (!result.isValid()) {
      throw new UrlStateUpdateException(
        "Url state update failed",
        ServiceErrorCodes.valueOf(result.getErrorCode()));
    }
  }

  private String encode(String input) {
    return Encode.forJava(input);
  }

  private String mask(String contact) {
    return MaskingUtil.maskContactInfo(encode(contact));
  }

  private boolean isNullOrEmpty(String val) {
    return val == null || val.isEmpty();
  }

  private void throwBadRequest(String field, String contact) {
    throw new InvalidRequestException(
      "Invalid " + field + " for contact: " + mask(contact),
      ServiceErrorCodes.BAD_REQUEST);
  }

  private void addString(Map<String, AttributeValue> map, String key, String value) {
  if (value == null) {
    throw new IllegalStateException("Missing required field: " + key);
  }
  map.put(key, AttributeValue.builder().s(value).build());
}

private void addNumber(Map<String, AttributeValue> map, String key, Long value) {
  if (value == null) {
    throw new IllegalStateException("Missing required field: " + key);
  }
  map.put(key, AttributeValue.builder().n(String.valueOf(value)).build());
}
}
