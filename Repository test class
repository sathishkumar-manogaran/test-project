@Test
void findByContact_withEmptyStatuses_onlyUsesWorkflowIndex() {
  String contact = "c1";
  String workflow = "WF01";

  UrlInformation u1 = url("u1", workflow, 2000L);

  when(workflowIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(List.of(u1))));

  List<UrlInformation> result =
      repo.findByContactAndJourneyCodeAndCreatedOn(contact, workflow, 1000L, Collections.emptyList());

  assertThat(result).hasSize(1);

  verify(statusIndex, never()).query(any());
}

@Test
void findByContact_workflowEmpty_statusProvidesResults() {
  when(workflowIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(Collections.emptyList())));

  UrlInformation s1 = url("u2", "WF01", 10L);

  when(statusIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(List.of(s1))));

  List<UrlInformation> result =
      repo.findByContactAndJourneyCodeAndCreatedOn("c1", "WF01", 1000L, List.of("ACTIVE"));

  assertThat(result).extracting("urlId").containsExactly("u2");
}

@Test
void findByContact_allFilteredOut_returnsEmpty() {
  UrlInformation old = url("u1", "WF01", 500L);

  when(workflowIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(List.of(old))));

  when(statusIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(Collections.emptyList())));

  List<UrlInformation> result =
      repo.findByContactAndJourneyCodeAndCreatedOn("c1", "WF01", 1000L, List.of("ACTIVE"));

  assertThat(result).isEmpty();
}

@Test
void findByContact_deduplicatesAcrossIndexes() {
  UrlInformation u1 = url("u1", "WF01", 2000L);

  when(workflowIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(List.of(u1))));

  when(statusIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(List.of(u1))));

  List<UrlInformation> result =
      repo.findByContactAndJourneyCodeAndCreatedOn("c1", "WF01", 1000L, List.of("ACTIVE"));

  assertThat(result).hasSize(1);
}

@Test
void findByContact_handlesNullCreatedOn_safely() {
  UrlInformation u1 = new UrlInformation();
  u1.setUrlId("u1");
  u1.setWorkflowCode("WF01");
  u1.setCreatedOn(null); // edge

  when(workflowIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(List.of(u1))));

  when(statusIndex.query(any()))
      .thenReturn(pageIterableOf(pageOf(Collections.emptyList())));

  List<UrlInformation> result =
      repo.findByContactAndJourneyCodeAndCreatedOn("c1", "WF01", 1000L, List.of("ACTIVE"));

  assertThat(result).isEmpty();
}



  private static UrlInformation url(String urlId, String workflowCode, Long createdOn) {
    UrlInformation u = new UrlInformation();
    u.setUrlId(urlId);
    u.setWorkflowCode(workflowCode);
    u.setCreatedOn(createdOn);
    return u;
  }

  private static Page<UrlInformation> pageOf(List<UrlInformation> items) {
    @SuppressWarnings("unchecked")
    Page<UrlInformation> page = mock(Page.class);
    when(page.items()).thenReturn(items);
    return page;
  }

  private static PageIterable<UrlInformation> pageIterableOf(Page<UrlInformation>... pages) {
    @SuppressWarnings("unchecked")
    PageIterable<UrlInformation> iterable = mock(PageIterable.class);
    when(iterable.iterator()).thenReturn(Arrays.asList(pages).iterator());
    return iterable;
  }
}
