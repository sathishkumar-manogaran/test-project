@Test
void generateUrl_transactionFails_shouldPropagateException() {
  GenerateUrlRequestData req = buildGenerateUrlReqData(
      "c1",
      JourneyCodeEnum.ACQ_JB,
      ContactTypeEnum.EMAIL,
      "partner",
      "org",
      Instant.now().plusSeconds(1000).toString()
  );

  UrlInformation prev = new UrlInformation();
  prev.setUrlId("u-prev");
  prev.setStatus(UrlStatusEnum.ACTIVE.getValue());

  when(repository.findByContactAndJourneyCodeAndCreatedOn(any(), any(), anyLong(), anyList()))
      .thenReturn(List.of(prev));

  when(factory.getService(OperationType.GENERATE_URL.name())).thenReturn(generateUrlValidator);
  when(generateUrlValidator.validate(anyList())).thenReturn(ValidationResult.valid());

  UrlInformation newUrl = new UrlInformation();
  newUrl.setUrlId("u-new");
  newUrl.setContact("c1");
  newUrl.setWorkflowCode("wf");
  newUrl.setStatus("ACTIVE");
  newUrl.setCreatedOn(1L);
  newUrl.setExpireOn(2L);
  newUrl.setCreatedBy("c");

  when(dynamicUrlServiceHelper.generateNewUrl(any(), anyString(), anyString(), any()))
      .thenReturn(newUrl);

  doThrow(RuntimeException.class)
      .when(dynamoDbClient).transactWriteItems(any());

  assertThrows(RuntimeException.class, () ->
      service.generateUrl("c","t","s", req, "ch","u"));
}

  private static GenerateUrlRequestData buildGenerateUrlReqData(
      String contact,
      JourneyCodeEnum journey,
      ContactTypeEnum contactType,
      String partnerCode,
      String partnerOrgUuid,
      String urlExpiry
  ) {
    GenerateUrlRequest r = new GenerateUrlRequest();
    r.setContact(contact);
    r.setJourneyCode(journey);
    r.setContactType(contactType);
    r.setPartnerCode(partnerCode);
    r.setPartnerOrgUUID(partnerOrgUuid);
    r.setUrlExpiry(urlExpiry);

    GenerateUrlRequestData d = new GenerateUrlRequestData();
    d.setData(r);
    return d;
  }

  private static void setField(Object target, String fieldName, Object value) throws Exception {
    var f = target.getClass().getDeclaredField(fieldName);
    f.setAccessible(true);
    f.set(target, value);
  }
