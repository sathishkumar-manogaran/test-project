  @Test
  void generateUrl_noExistingUrls_savesNewUrl_andReturnsResponse() {
    GenerateUrlRequestData reqData = buildGenerateUrlReqData(
        "test@example.com",
        JourneyCodeEnum.ACQ_JB,
        ContactTypeEnum.EMAIL,
        "partner",
        "org-uuid",
        Instant.now().plusSeconds(3600).toString()
    );

    when(repository.findByContactAndJourneyCodeAndCreatedOn(
        eq("test@example.com"),
        eq(reqData.getData().getJourneyCode().getValue()),
        eq(0L),
        anyList()
    )).thenReturn(Collections.emptyList());

    UrlInformation newUrl = new UrlInformation();
    newUrl.setUrlId("u-new");
    newUrl.setContact("test@example.com");
    newUrl.setWorkflowCode(reqData.getData().getJourneyCode().getValue());
    newUrl.setStatus(UrlStatusEnum.ACTIVE.getValue());
    newUrl.setUrl("https://x/y");
    newUrl.setCreatedOn(100L);
    newUrl.setExpireOn(999L);
    newUrl.setCreatedBy("channel");
    newUrl.setUpdatedBy("user");

    when(dynamicUrlServiceHelper.generateNewUrl(any(), anyString(), anyString(), isNull()))
        .thenReturn(newUrl);

    GenerateUrlResponseData expected = new GenerateUrlResponseData()
        .data(new GenerateUrlResponse().url("https://x/y"));

    try (MockedStatic<ResponseProcessor> mocked = mockStatic(ResponseProcessor.class)) {
      mocked.when(() -> ResponseProcessor.processGenerateURLResponse(newUrl)).thenReturn(expected);

      GenerateUrlResponseData actual = service.generateUrl(
          "corr", "trace", "span",
          reqData,
          "channel",
          "user"
      );

      assertSame(expected, actual);
    }

    verify(repository).save(newUrl);
    verify(dynamoDbClient, never()).transactWriteItems(any(TransactWriteItemsRequest.class));
    verify(factory, never()).getService(OperationType.GENERATE_URL.name());
  }

