  @Test
  void generateUrl_existingActivePrevUrl_executesTransaction_insteadOfSave() {
    GenerateUrlRequestData reqData = buildGenerateUrlReqData(
        "c1",
        JourneyCodeEnum.ACQ_JB,
        ContactTypeEnum.EMAIL,
        "partner",
        "org-uuid",
        Instant.now().plusSeconds(3600).toString()
    );

    UrlInformation prev = new UrlInformation();
    prev.setUrlId("u-prev");
    prev.setStatus(UrlStatusEnum.ACTIVE.getValue());

    when(repository.findByContactAndJourneyCodeAndCreatedOn(anyString(), anyString(), anyLong(), anyList()))
        .thenReturn(List.of(prev));

    when(factory.getService(OperationType.GENERATE_URL.name())).thenReturn(generateUrlValidator);
    when(generateUrlValidator.validate(anyList())).thenReturn(ValidationResult.valid());

    UrlInformation newUrl = new UrlInformation();
    newUrl.setUrlId("u-new");
    newUrl.setContact("c1");
    newUrl.setWorkflowCode(reqData.getData().getJourneyCode().getValue());
    newUrl.setStatus(UrlStatusEnum.ACTIVE.getValue());
    newUrl.setCreatedOn(111L);
    newUrl.setExpireOn(222L);
    newUrl.setCreatedBy("channel");
    newUrl.setUpdatedBy("user");

    when(dynamicUrlServiceHelper.generateNewUrl(any(), anyString(), anyString(), eq(prev)))
        .thenReturn(newUrl);

    GenerateUrlResponseData expected = new GenerateUrlResponseData()
        .data(new GenerateUrlResponse().url("dummy"));

    ArgumentCaptor<TransactWriteItemsRequest> txCaptor = ArgumentCaptor.forClass(TransactWriteItemsRequest.class);

    try (MockedStatic<ResponseProcessor> mocked = mockStatic(ResponseProcessor.class)) {
      mocked.when(() -> ResponseProcessor.processGenerateURLResponse(newUrl)).thenReturn(expected);

      GenerateUrlResponseData actual = service.generateUrl("corr", "trace", "span", reqData, "channel", "user");
      assertSame(expected, actual);
    }

    verify(repository, never()).save(any());
    verify(dynamoDbClient).transactWriteItems(txCaptor.capture());

    TransactWriteItemsRequest tx = txCaptor.getValue();
    assertEquals(2, tx.transactItems().size());

    Update update = tx.transactItems().get(0).update();
    assertNotNull(update);
    assertEquals("tbl_dynamic_url", update.tableName());
    assertEquals("#st = :active", update.conditionExpression());
    assertTrue(update.updateExpression().contains("SET #st = :inactive"));
    assertEquals("status", update.expressionAttributeNames().get("#st"));
    assertEquals("ACTIVE", update.expressionAttributeValues().get(":active").s());
    assertEquals("INACTIVE", update.expressionAttributeValues().get(":inactive").s());
    assertNotNull(update.expressionAttributeValues().get(":now").n());
    assertEquals("user", update.expressionAttributeValues().get(":user").s());

    Put put = tx.transactItems().get(1).put();
    assertNotNull(put);
    assertEquals("tbl_dynamic_url", put.tableName());
    assertEquals("attribute_not_exists(urlId)", put.conditionExpression());
    assertEquals("u-new", put.item().get("urlId").s());
    assertEquals("c1", put.item().get("contact").s());
    assertEquals(reqData.getData().getJourneyCode().getValue(), put.item().get("workflowCode").s());
    assertEquals("ACTIVE", put.item().get("status").s());
  }

