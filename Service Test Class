  @Test
  void updateURLState_happyPath_delegatesToStateService_andReturnsProcessedResponse() {
    UrlInformation urlInfo = new UrlInformation();
    urlInfo.setUrlId("u1");

    when(repository.findByUrlId("u1")).thenReturn(urlInfo);

    when(factory.getService(OperationType.URL_STATE_UPDATE.name())).thenReturn(urlStateUpdateValidator);
    when(urlStateUpdateValidator.validate(anyList())).thenReturn(ValidationResult.valid());

    UrlStateUpdateRequest inner = new UrlStateUpdateRequest()
        .stateAttribute(UrlStateAttrEnum.URL_ACCESS_STATE)
        .stateAttributeValue("SUCCESS");

    UrlStateUpdateReqData req = new UrlStateUpdateReqData().data(inner);

    when(factory.getService(UrlStateAttrEnum.URL_ACCESS_STATE.name())).thenReturn(urlAccessStateService);

    UrlInformation updated = new UrlInformation();
    updated.setUrlId("u1");
    updated.setStatus(UrlStatusEnum.ACTIVE.getValue());

    when(urlAccessStateService.updateUrlState(eq(inner), eq(urlInfo), eq("user")))
        .thenReturn(updated);

    URLInformationData expected = new URLInformationData();
    expected.setData(new URLDetails().urlId("u1").status("ACTIVE"));

    try (MockedStatic<ResponseProcessor> mocked = mockStatic(ResponseProcessor.class)) {
      mocked.when(() -> ResponseProcessor.processUrlDetailsResponse(updated)).thenReturn(expected);

      URLInformationData actual = service.updateURLState("corr", "trace", "span", "u1", req, "user");
      assertSame(expected, actual);
    }

    verify(urlAccessStateService).updateUrlState(eq(inner), eq(urlInfo), eq("user"));
  }

