package com.barclaycardus.dynamicurl.service.impl;

import com.barclaycardus.dynamicurl.constant.enums.ServiceErrorCodes;
import com.barclaycardus.dynamicurl.entity.UrlInformation;
import com.barclaycardus.dynamicurl.exception.GenerateURLValidationException;
import com.barclaycardus.dynamicurl.exception.InvalidRequestException;
import com.barclaycardus.dynamicurl.exception.ResourceNotFoundException;
import com.barclaycardus.dynamicurl.exception.UrlStateUpdateException;
import com.barclaycardus.dynamicurl.model.*;
import com.barclaycardus.dynamicurl.processor.ResponseProcessor;
import com.barclaycardus.dynamicurl.repository.UrlDynamoDbRepository;
import com.barclaycardus.dynamicurl.service.URLValidatorService;
import com.barclaycardus.dynamicurl.service.factory.ServiceFactory;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.*;
import org.mockito.junit.jupiter.MockitoExtension;
import software.amazon.awssdk.services.dynamodb.DynamoDbClient;
import software.amazon.awssdk.services.dynamodb.model.*;

import java.time.Instant;
import java.util.*;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class DynamicUrlServiceImplTest {

  @Mock DynamoDbClient dynamoDbClient;
  @Mock UrlDynamoDbRepository repository;
  @Mock DynamicUrlServiceHelper dynamicUrlServiceHelper;
  @Mock ServiceFactory factory;
  @Mock ResponseProcessor responseProcessor;

  @Mock URLValidatorService generateUrlValidator;
  @Mock URLValidatorService validateUrlValidator;
  @Mock URLValidatorService urlStateUpdateValidator;

  @Mock UrlStateUpdateService urlAccessStateService;

  @InjectMocks DynamicUrlServiceImpl service;

  private static final String CONTACT = "c1";
  private static final String CHANNEL = "ch";
  private static final String USER = "user";
  private static final String URL_ID = "u1";

  @BeforeEach
  void init() throws Exception {
    setField(service, "tableName", "tbl_dynamic_url");
  }

  @Test
  void generateUrl_noExistingUrls_shouldSave() {
    GenerateUrlRequestData req = buildReq();

    when(repository.findByContactAndJourneyCodeAndCreatedOn(
        CONTACT,
        JourneyCodeEnum.ACQ_JB.getValue(),
        0L,
        Arrays.asList("ADMIN_LOCKED", "ACTIVE")
    )).thenReturn(Collections.emptyList());

    UrlInformation newUrl = new UrlInformation();
    newUrl.setUrlId("new1");

    when(dynamicUrlServiceHelper.generateNewUrl(req.getData(), USER, CHANNEL, null))
        .thenReturn(newUrl);

    GenerateUrlResponseData expected = new GenerateUrlResponseData();
    when(responseProcessor.processGenerateURLResponse(newUrl)).thenReturn(expected);

    GenerateUrlResponseData result =
        service.generateUrl("c","t","s", req, CHANNEL, USER);

    assertSame(expected, result);
    verify(repository).save(newUrl);
  }

  @Test
  void generateUrl_existingInactive_shouldSaveNewUrl() {
    GenerateUrlRequestData req = buildReq();

    UrlInformation old = new UrlInformation();
    old.setStatus("INACTIVE");

    when(repository.findByContactAndJourneyCodeAndCreatedOn(
        CONTACT, JourneyCodeEnum.ACQ_JB.getValue(), 0L,
        Arrays.asList("ADMIN_LOCKED", "ACTIVE")
    )).thenReturn(List.of(old));

    when(factory.getService(OperationType.GENERATE_URL.name()))
        .thenReturn(generateUrlValidator);

    when(generateUrlValidator.validate(List.of(old)))
        .thenReturn(ValidationResult.valid());

    UrlInformation newUrl = new UrlInformation();

    when(dynamicUrlServiceHelper.generateNewUrl(req.getData(), USER, CHANNEL, null))
        .thenReturn(newUrl);

    when(responseProcessor.processGenerateURLResponse(newUrl))
        .thenReturn(new GenerateUrlResponseData());

    service.generateUrl("c","t","s", req, CHANNEL, USER);

    verify(repository).save(newUrl);
    verify(dynamoDbClient, never()).transactWriteItems(any());
  }

  @Test
  void generateUrl_existingActive_shouldTriggerTransaction() {
    GenerateUrlRequestData req = buildReq();

    UrlInformation prev = new UrlInformation();
    prev.setUrlId("u-old");
    prev.setStatus("ACTIVE");

    when(repository.findByContactAndJourneyCodeAndCreatedOn(
        CONTACT, JourneyCodeEnum.ACQ_JB.getValue(), 0L,
        Arrays.asList("ADMIN_LOCKED", "ACTIVE")
    )).thenReturn(List.of(prev));

    when(factory.getService(OperationType.GENERATE_URL.name()))
        .thenReturn(generateUrlValidator);

    when(generateUrlValidator.validate(List.of(prev)))
        .thenReturn(ValidationResult.valid());

    UrlInformation newUrl = new UrlInformation();
    newUrl.setUrlId("u-new");
    newUrl.setContact(CONTACT);
    newUrl.setWorkflowCode("wf");
    newUrl.setStatus("ACTIVE");
    newUrl.setCreatedOn(1L);
    newUrl.setExpireOn(2L);
    newUrl.setCreatedBy("c");

    when(dynamicUrlServiceHelper.generateNewUrl(req.getData(), USER, CHANNEL, prev))
        .thenReturn(newUrl);

    when(responseProcessor.processGenerateURLResponse(newUrl))
        .thenReturn(new GenerateUrlResponseData());

    service.generateUrl("c","t","s", req, CHANNEL, USER);

    verify(dynamoDbClient).transactWriteItems(any());
    verify(repository, never()).save(any());
  }

  @Test
  void generateUrl_validatorFails_shouldThrow() {
    GenerateUrlRequestData req = buildReq();

    UrlInformation existing = new UrlInformation();

    when(repository.findByContactAndJourneyCodeAndCreatedOn(
        CONTACT, JourneyCodeEnum.ACQ_JB.getValue(), 0L,
        Arrays.asList("ADMIN_LOCKED", "ACTIVE")
    )).thenReturn(List.of(existing));

    when(factory.getService(OperationType.GENERATE_URL.name()))
        .thenReturn(generateUrlValidator);

    when(generateUrlValidator.validate(List.of(existing)))
        .thenReturn(ValidationResult.invalid("URL_GEN_THRESHOLD_REACHED"));

    assertThrows(GenerateURLValidationException.class,
        () -> service.generateUrl("c","t","s", req, CHANNEL, USER));
  }

  @Test
  void generateUrl_invalidContact_shouldThrow() {
    GenerateUrlRequestData req = buildReq(null);

    assertThrows(InvalidRequestException.class,
        () -> service.generateUrl("c","t","s", req, CHANNEL, USER));
  }

  @Test
  void generateUrl_expiryPast_shouldThrow() {
    GenerateUrlRequestData req = buildReq();
    req.getData().setUrlExpiry(Instant.now().minusSeconds(10).toString());

    assertThrows(InvalidRequestException.class,
        () -> service.generateUrl("c","t","s", req, CHANNEL, USER));
  }

  @Test
  void generateUrl_expiryInvalidFormat_shouldThrow() {
    GenerateUrlRequestData req = buildReq();
    req.getData().setUrlExpiry("invalid");

    assertThrows(InvalidRequestException.class,
        () -> service.generateUrl("c","t","s", req, CHANNEL, USER));
  }

  @Test
  void validateUrl_success() {
    UrlInformation url = new UrlInformation();

    when(repository.findByUrlId(URL_ID)).thenReturn(url);

    when(factory.getService(OperationType.VALIDATE_URL.name()))
        .thenReturn(validateUrlValidator);

    when(validateUrlValidator.validate(List.of(url)))
        .thenReturn(ValidationResult.valid());

    ValidateUrlResponseData expected = new ValidateUrlResponseData();
    when(responseProcessor.processValidateUrlResponse(any()))
        .thenReturn(expected);

    assertSame(expected,
        service.validateUrl("c","t","s", URL_ID));
  }

  @Test
  void validateUrl_notFound_shouldThrow() {
    when(repository.findByUrlId(URL_ID)).thenReturn(null);

    assertThrows(ResourceNotFoundException.class,
        () -> service.validateUrl("c","t","s", URL_ID));
  }

  @Test
  void getURLDetail_success_shouldSetExpiry() {
    UrlInformation url = new UrlInformation();
    url.setExpireOn(123L);

    when(repository.findByUrlId(URL_ID)).thenReturn(url);

    URLInformationData data = new URLInformationData();
    data.setData(new URLDetails());

    when(responseProcessor.processUrlDetailsResponse(url))
        .thenReturn(data);

    URLInformationData result =
        service.getURLDetail("c","t","s", URL_ID);

    assertEquals("123", result.getData().getUrlExpiry());
  }

  @Test
  void getURLDetail_notFound_shouldThrow() {
    when(repository.findByUrlId(URL_ID)).thenReturn(null);

    assertThrows(ResourceNotFoundException.class,
        () -> service.getURLDetail("c","t","s", URL_ID));
  }

  @Test
  void updateURLState_success() {
    UrlInformation url = new UrlInformation();

    when(repository.findByUrlId(URL_ID)).thenReturn(url);

    when(factory.getService(OperationType.URL_STATE_UPDATE.name()))
        .thenReturn(urlStateUpdateValidator);

    when(urlStateUpdateValidator.validate(List.of(url)))
        .thenReturn(ValidationResult.valid());

    UrlStateUpdateRequest req =
        new UrlStateUpdateRequest().stateAttribute(UrlStateAttrEnum.URL_ACCESS_STATE);

    when(factory.getService(UrlStateAttrEnum.URL_ACCESS_STATE.name()))
        .thenReturn(urlAccessStateService);

    UrlInformation updated = new UrlInformation();

    when(urlAccessStateService.updateUrlState(req, url, USER))
        .thenReturn(updated);

    URLInformationData expected = new URLInformationData();
    when(responseProcessor.processUrlDetailsResponse(updated))
        .thenReturn(expected);

    assertSame(expected,
        service.updateURLState("c","t","s", URL_ID,
            new UrlStateUpdateReqData().data(req), USER));
  }

  @Test
  void updateURLState_notFound_shouldThrow() {
    when(repository.findByUrlId(URL_ID)).thenReturn(null);

    assertThrows(ResourceNotFoundException.class,
        () -> service.updateURLState("c","t","s", URL_ID,
            new UrlStateUpdateReqData(), USER));
  }

  @Test
  void updateURLState_validationFails_shouldThrow() {
    UrlInformation url = new UrlInformation();

    when(repository.findByUrlId(URL_ID)).thenReturn(url);

    when(factory.getService(OperationType.URL_STATE_UPDATE.name()))
        .thenReturn(urlStateUpdateValidator);

    when(urlStateUpdateValidator.validate(List.of(url)))
        .thenReturn(ValidationResult.invalid("URL_LOCKED"));

    assertThrows(UrlStateUpdateException.class,
        () -> service.updateURLState("c","t","s", URL_ID,
            new UrlStateUpdateReqData(), USER));
  }

  private GenerateUrlRequestData buildReq() {
    return buildReq(CONTACT);
  }

  private GenerateUrlRequestData buildReq(String contact) {
    GenerateUrlRequest r = new GenerateUrlRequest();
    r.setContact(contact);
    r.setJourneyCode(JourneyCodeEnum.ACQ_JB);
    r.setContactType(ContactTypeEnum.EMAIL);
    r.setPartnerCode("p");
    r.setPartnerOrgUUID("org");
    r.setUrlExpiry(Instant.now().plusSeconds(1000).toString());

    GenerateUrlRequestData d = new GenerateUrlRequestData();
    d.setData(r);
    return d;
  }

  private static void setField(Object target, String field, Object val) throws Exception {
    var f = target.getClass().getDeclaredField(field);
    f.setAccessible(true);
    f.set(target, val);
  }
}
